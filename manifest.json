{
  "manifest_version": 3,
  "name": "RTL Text Fixer",
  "version": "4.1.0",
  "description": "A dedicated RTL Element Inspector (Ctrl+Shift+E) and popup tool to fix Arabic & RTL text.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/rtl-icon.png",
      "32": "icons/rtl-icon.png",
      "48": "icons/rtl-icon.png",
      "128": "icons/rtl-icon.png"
    },
    "default_title": "RTL Text Fixer"
  },
  "icons": {
    "16": "icons/rtl-icon.png",
    "32": "icons/rtl-icon.png",
    "48": "icons/rtl-icon.png",
    "128": "icons/rtl-icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "clipboardWrite",
    "clipboardRead",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}